<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingVertical="@dimen/spacing_sm"
    android:paddingHorizontal="@dimen/spacing_xs">

    <!-- Rank number -->
    <TextView
        android:id="@+id/tvRank"
        android:layout_width="28dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textAppearance="@style/TextAppearance.Eco.Label"
        android:textColor="@color/text_muted"
        tools:text="#1" />

    <!-- Avatar -->
    <ImageView
        android:id="@+id/ivAvatar"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginStart="@dimen/spacing_sm"
        android:background="@drawable/bg_avatar_circle"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_person_24"
        android:contentDescription="Member avatar" />

    <!-- Name -->
    <TextView
        android:id="@+id/tvMemberName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="@dimen/spacing_md"
        android:ellipsize="end"
        android:maxLines="1"
        android:textAppearance="@style/TextAppearance.Eco.Body"
        android:textColor="@color/text_primary"
        tools:text="Alex Johnson" />

    <!-- Points -->
    <TextView
        android:id="@+id/tvMemberPoints"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textAppearance="@style/TextAppearance.Eco.Label"
        android:textColor="@color/accent_green"
        tools:text="1,250 pts" />
</LinearLayout>
