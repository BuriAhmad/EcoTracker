<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_deep">

    <!-- ── Header ──────────────────────────────────────────────── -->
    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="@dimen/icon_large"
        android:layout_height="@dimen/icon_large"
        android:layout_marginStart="@dimen/screen_padding_horizontal"
        android:layout_marginTop="@dimen/screen_padding_top"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_arrow_back_24"
        android:contentDescription="Back"
        app:tint="@color/text_primary"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Teams"
        android:textAppearance="@style/TextAppearance.Eco.HeadlineLarge"
        android:textColor="@color/text_primary"
        app:layout_constraintStart_toEndOf="@id/btnBack"
        app:layout_constraintTop_toTopOf="@id/btnBack"
        app:layout_constraintBottom_toBottomOf="@id/btnBack"
        android:layout_marginStart="@dimen/spacing_sm" />

    <!-- ── Filter Chips ────────────────────────────────────────── -->
    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chipGroupFilter"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_md"
        android:paddingHorizontal="@dimen/screen_padding_horizontal"
        app:singleSelection="true"
        app:selectionRequired="true"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnBack">

        <com.google.android.material.chip.Chip
            android:id="@+id/chipAll"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="All"
            android:checked="true"
            android:textColor="@color/text_primary"
            app:chipBackgroundColor="@color/bg_card"
            app:checkedIconEnabled="false"
            app:chipStrokeColor="@color/accent_green"
            app:chipStrokeWidth="1dp" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipClubs"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Clubs"
            android:textColor="@color/text_primary"
            app:chipBackgroundColor="@color/bg_card"
            app:checkedIconEnabled="false"
            app:chipStrokeColor="@color/accent_cyan"
            app:chipStrokeWidth="1dp" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipDepartments"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Departments"
            android:textColor="@color/text_primary"
            app:chipBackgroundColor="@color/bg_card"
            app:checkedIconEnabled="false"
            app:chipStrokeColor="@color/accent_violet"
            app:chipStrokeWidth="1dp" />
    </com.google.android.material.chip.ChipGroup>

    <!-- ── Team list ───────────────────────────────────────────── -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvTeams"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/spacing_md"
        android:paddingHorizontal="@dimen/screen_padding_horizontal"
        android:clipToPadding="false"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/chipGroupFilter"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:listitem="@layout/item_team" />

    <!-- ── Loading ─────────────────────────────────────────────── -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminateTint="@color/accent_green"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/rvTeams"
        app:layout_constraintBottom_toBottomOf="@id/rvTeams" />

    <!-- ── Empty state ─────────────────────────────────────────── -->
    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="No teams yet.\nCreate one!"
        android:textAppearance="@style/TextAppearance.Eco.Body"
        android:textColor="@color/text_muted"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/rvTeams"
        app:layout_constraintBottom_toBottomOf="@id/rvTeams" />

    <!-- ── FAB: Create Team ────────────────────────────────────── -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabCreate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/spacing_base"
        android:src="@drawable/ic_add_24"
        android:contentDescription="Create team"
        app:backgroundTint="@color/accent_green"
        app:tint="@color/text_on_accent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
