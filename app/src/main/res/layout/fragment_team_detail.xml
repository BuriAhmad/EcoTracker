<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_deep">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/screen_padding_horizontal"
        android:paddingTop="@dimen/screen_padding_top"
        android:paddingBottom="@dimen/screen_padding_bottom">

        <!-- ── Back button ──────────────────────────────────────── -->
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="@dimen/icon_large"
            android:layout_height="@dimen/icon_large"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back_24"
            android:contentDescription="Back"
            app:tint="@color/text_primary" />

        <!-- ── Hero: Team Initial + Name ────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xl"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvTeamInitial"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/bg_avatar_circle"
                android:gravity="center"
                android:textColor="@color/text_on_accent"
                android:textSize="32sp"
                android:textStyle="bold"
                tools:text="E" />

            <TextView
                android:id="@+id/tvTeamName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:textAppearance="@style/TextAppearance.Eco.HeadlineMedium"
                android:textColor="@color/text_primary"
                tools:text="Eco Warriors" />

            <TextView
                android:id="@+id/tvTeamType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xxs"
                android:textAppearance="@style/TextAppearance.Eco.Label"
                android:textColor="@color/text_muted"
                tools:text="Club" />

            <TextView
                android:id="@+id/tvDescription"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:gravity="center"
                android:textAppearance="@style/TextAppearance.Eco.Body"
                android:textColor="@color/text_secondary"
                tools:text="A group of eco-enthusiasts working to make campus greener!" />
        </LinearLayout>

        <!-- ── Stats Row (3 columns) ──────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xl"
            android:orientation="horizontal"
            android:weightSum="3"
            android:background="@drawable/bg_glass_card"
            android:padding="@dimen/card_padding">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvStatMembers"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.Eco.StatValue"
                    android:textColor="@color/accent_cyan"
                    tools:text="12" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Members"
                    android:textAppearance="@style/TextAppearance.Eco.StatUnit"
                    android:textColor="@color/text_muted" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvStatPoints"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.Eco.StatValue"
                    android:textColor="@color/accent_green"
                    tools:text="2,450" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Points"
                    android:textAppearance="@style/TextAppearance.Eco.StatUnit"
                    android:textColor="@color/text_muted" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvStatAvgPoints"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.Eco.StatValue"
                    android:textColor="@color/accent_amber"
                    tools:text="204" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Avg/Member"
                    android:textAppearance="@style/TextAppearance.Eco.StatUnit"
                    android:textColor="@color/text_muted" />
            </LinearLayout>
        </LinearLayout>

        <!-- ── Join / Leave Button ─────────────────────────────── -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnJoinLeave"
            style="@style/Widget.Material3.Button"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="@dimen/spacing_base"
            android:text="Join Team"
            android:textColor="@color/text_on_accent"
            app:backgroundTint="@color/accent_green" />

        <!-- ── Members Section ─────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xl"
            android:text="Members"
            android:textAppearance="@style/TextAppearance.Eco.TitleMedium"
            android:textColor="@color/text_primary" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvMembers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:nestedScrollingEnabled="false"
            tools:listitem="@layout/item_team_member"
            tools:itemCount="5" />

        <!-- ── Loading ─────────────────────────────────────────── -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/spacing_base"
            android:indeterminateTint="@color/accent_green"
            android:visibility="gone" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
