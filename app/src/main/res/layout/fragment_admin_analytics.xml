<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_deep">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/screen_padding_horizontal"
        android:paddingTop="@dimen/screen_padding_top"
        android:paddingBottom="@dimen/screen_padding_bottom">

        <!-- ── Header ──────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="@dimen/icon_large"
                android:layout_height="@dimen/icon_large"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_arrow_back_24"
                android:contentDescription="Back"
                app:tint="@color/text_primary" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/spacing_sm"
                android:text="Admin Panel"
                android:textAppearance="@style/TextAppearance.Eco.HeadlineLarge"
                android:textColor="@color/text_primary" />
        </LinearLayout>

        <!-- ── Campus Stats Grid (2x2) ─────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xl"
            android:text="Campus Overview"
            android:textAppearance="@style/TextAppearance.Eco.TitleMedium"
            android:textColor="@color/text_primary" />

        <androidx.gridlayout.widget.GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            app:columnCount="2"
            app:rowCount="2"
            app:useDefaultMargins="true">

            <!-- Total Users -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Eco.Card"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:layout_columnWeight="1"
                app:layout_rowWeight="1">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="👥 Users"
                        android:textAppearance="@style/TextAppearance.Eco.LabelSmall"
                        android:textColor="@color/text_muted" />

                    <TextView
                        android:id="@+id/tvStatUsers"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:textAppearance="@style/TextAppearance.Eco.StatValue"
                        android:textColor="@color/accent_green"
                        tools:text="156" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Active Challenges -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Eco.Card"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:layout_columnWeight="1"
                app:layout_rowWeight="1">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🏆 Challenges"
                        android:textAppearance="@style/TextAppearance.Eco.LabelSmall"
                        android:textColor="@color/text_muted" />

                    <TextView
                        android:id="@+id/tvStatChallenges"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:textAppearance="@style/TextAppearance.Eco.StatValue"
                        android:textColor="@color/accent_amber"
                        tools:text="8" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Teams -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Eco.Card"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:layout_columnWeight="1"
                app:layout_rowWeight="1">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🤝 Teams"
                        android:textAppearance="@style/TextAppearance.Eco.LabelSmall"
                        android:textColor="@color/text_muted" />

                    <TextView
                        android:id="@+id/tvStatTeams"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:textAppearance="@style/TextAppearance.Eco.StatValue"
                        android:textColor="@color/accent_cyan"
                        tools:text="12" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Total CO2 Saved -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Eco.Card"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:layout_columnWeight="1"
                app:layout_rowWeight="1">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌿 CO₂ Saved"
                        android:textAppearance="@style/TextAppearance.Eco.LabelSmall"
                        android:textColor="@color/text_muted" />

                    <TextView
                        android:id="@+id/tvStatCo2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:textAppearance="@style/TextAppearance.Eco.StatValue"
                        android:textColor="@color/accent_green"
                        tools:text="45.2 kg" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </androidx.gridlayout.widget.GridLayout>

        <!-- ── Top Students Section ────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xl"
            android:text="Top Students"
            android:textAppearance="@style/TextAppearance.Eco.TitleMedium"
            android:textColor="@color/text_primary" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvTopStudents"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:nestedScrollingEnabled="false"
            tools:listitem="@layout/item_team_member"
            tools:itemCount="5" />

        <!-- ── Quick Actions ───────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xl"
            android:text="Quick Actions"
            android:textAppearance="@style/TextAppearance.Eco.TitleMedium"
            android:textColor="@color/text_primary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCreateChallenge"
            style="@style/Widget.Material3.Button"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="@dimen/spacing_md"
            android:text="Create New Challenge"
            android:textColor="@color/text_on_accent"
            app:backgroundTint="@color/accent_green"
            app:icon="@drawable/ic_add_24"
            app:iconTint="@color/text_on_accent" />

        <!-- ── Loading ─────────────────────────────────────────── -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/spacing_base"
            android:indeterminateTint="@color/accent_green"
            android:visibility="gone" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
