<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingVertical="@dimen/spacing_sm"
    android:paddingHorizontal="@dimen/spacing_xs"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <!-- Icon -->
    <ImageView
        android:id="@+id/ivSearchIcon"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:padding="8dp"
        android:background="@drawable/bg_avatar_circle"
        android:scaleType="centerInside"
        app:tint="@color/text_on_accent"
        android:contentDescription="Result icon"
        tools:src="@drawable/ic_flag_24" />

    <!-- Text content -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="@dimen/spacing_md"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvSearchTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textAppearance="@style/TextAppearance.Eco.Body"
            android:textColor="@color/text_primary"
            tools:text="Bike to Campus Challenge" />

        <TextView
            android:id="@+id/tvSearchSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textAppearance="@style/TextAppearance.Eco.LabelSmall"
            android:textColor="@color/text_muted"
            tools:text="Challenge · 5 days left" />
    </LinearLayout>

    <!-- Arrow -->
    <ImageView
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_marginStart="@dimen/spacing_sm"
        android:src="@drawable/ic_arrow_back_24"
        android:rotation="180"
        app:tint="@color/text_muted"
        android:contentDescription="View" />
</LinearLayout>
