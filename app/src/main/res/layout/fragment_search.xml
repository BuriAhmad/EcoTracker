<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_deep">

    <!-- ── Back + Search Bar ───────────────────────────────── -->
    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="@dimen/icon_large"
        android:layout_height="@dimen/icon_large"
        android:layout_marginStart="@dimen/screen_padding_horizontal"
        android:layout_marginTop="@dimen/screen_padding_top"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_arrow_back_24"
        android:contentDescription="Back"
        app:tint="@color/text_primary"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilSearch"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_sm"
        android:layout_marginEnd="@dimen/screen_padding_horizontal"
        app:boxStrokeColor="@color/accent_green"
        app:hintTextColor="@color/accent_green"
        app:startIconDrawable="@drawable/ic_search_24"
        app:startIconTint="@color/text_muted"
        app:layout_constraintStart_toEndOf="@id/btnBack"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/btnBack"
        app:layout_constraintBottom_toBottomOf="@id/btnBack">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etSearch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Search challenges, teams…"
            android:inputType="text"
            android:imeOptions="actionSearch"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_muted" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- ── Filter Chips ────────────────────────────────────── -->
    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chipGroupFilter"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_md"
        android:paddingHorizontal="@dimen/screen_padding_horizontal"
        app:singleSelection="true"
        app:selectionRequired="true"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tilSearch">

        <com.google.android.material.chip.Chip
            android:id="@+id/chipAll"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="All"
            android:checked="true"
            android:textColor="@color/text_primary"
            app:chipBackgroundColor="@color/bg_card"
            app:checkedIconEnabled="false"
            app:chipStrokeColor="@color/accent_green"
            app:chipStrokeWidth="1dp" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipChallenges"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Challenges"
            android:textColor="@color/text_primary"
            app:chipBackgroundColor="@color/bg_card"
            app:checkedIconEnabled="false"
            app:chipStrokeColor="@color/accent_amber"
            app:chipStrokeWidth="1dp" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipTeams"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Teams"
            android:textColor="@color/text_primary"
            app:chipBackgroundColor="@color/bg_card"
            app:checkedIconEnabled="false"
            app:chipStrokeColor="@color/accent_cyan"
            app:chipStrokeWidth="1dp" />
    </com.google.android.material.chip.ChipGroup>

    <!-- ── Results ─────────────────────────────────────────── -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvResults"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/spacing_sm"
        android:paddingHorizontal="@dimen/screen_padding_horizontal"
        android:clipToPadding="false"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/chipGroupFilter"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:listitem="@layout/item_search_result" />

    <!-- ── Loading ─────────────────────────────────────────── -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminateTint="@color/accent_green"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/rvResults"
        app:layout_constraintBottom_toBottomOf="@id/rvResults" />

    <!-- ── Empty state ─────────────────────────────────────── -->
    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Search for challenges and teams"
        android:textAppearance="@style/TextAppearance.Eco.Body"
        android:textColor="@color/text_muted"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/rvResults"
        app:layout_constraintBottom_toBottomOf="@id/rvResults" />

</androidx.constraintlayout.widget.ConstraintLayout>
