<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cardTeam"
    style="@style/Widget.Eco.Card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_sm"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="@dimen/card_padding">

        <!-- Colored left border + initials circle -->
        <FrameLayout
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center_vertical">

            <TextView
                android:id="@+id/tvInitial"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_avatar_circle"
                android:gravity="center"
                android:textColor="@color/text_on_accent"
                android:textSize="20sp"
                android:textStyle="bold"
                tools:text="E" />
        </FrameLayout>

        <!-- Team info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="@dimen/spacing_md"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvTeamName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textAppearance="@style/TextAppearance.Eco.TitleMedium"
                android:textColor="@color/text_primary"
                tools:text="Eco Warriors" />

            <TextView
                android:id="@+id/tvTeamType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textAppearance="@style/TextAppearance.Eco.LabelSmall"
                android:textColor="@color/text_muted"
                tools:text="Club" />

            <!-- Stats row -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_group_24"
                    app:tint="@color/text_muted"
                    android:contentDescription="Members" />

                <TextView
                    android:id="@+id/tvMemberCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:textAppearance="@style/TextAppearance.Eco.LabelSmall"
                    android:textColor="@color/text_secondary"
                    tools:text="12 members" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="12dp"
                    android:layout_marginHorizontal="@dimen/spacing_sm"
                    android:background="@color/divider" />

                <TextView
                    android:id="@+id/tvTeamPoints"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.Eco.LabelSmall"
                    android:textColor="@color/accent_green"
                    tools:text="2,450 pts" />
            </LinearLayout>
        </LinearLayout>

        <!-- Arrow -->
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center_vertical"
            android:src="@drawable/ic_arrow_back_24"
            android:rotation="180"
            app:tint="@color/text_muted"
            android:contentDescription="View team" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
