<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_deep">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/screen_padding_horizontal"
        android:paddingTop="@dimen/screen_padding_top"
        android:paddingBottom="@dimen/screen_padding_bottom">

        <!-- ── Back button ──────────────────────────────────────── -->
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="@dimen/icon_large"
            android:layout_height="@dimen/icon_large"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back_24"
            android:contentDescription="Back"
            app:tint="@color/text_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:text="Create Team"
            android:textAppearance="@style/TextAppearance.Eco.HeadlineLarge"
            android:textColor="@color/text_primary" />

        <!-- ── Team Name ────────────────────────────────────────── -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilTeamName"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xl"
            android:hint="Team Name"
            app:boxStrokeColor="@color/accent_green"
            app:hintTextColor="@color/accent_green">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etTeamName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapWords"
                android:maxLength="50"
                android:textColor="@color/text_primary" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- ── Team Type Chips ──────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xl"
            android:text="Team Type"
            android:textAppearance="@style/TextAppearance.Eco.TitleMedium"
            android:textColor="@color/text_primary" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            app:singleSelection="true"
            app:selectionRequired="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipClub"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Club"
                android:checked="true"
                android:textColor="@color/text_primary"
                app:chipBackgroundColor="@color/bg_card"
                app:checkedIconEnabled="false"
                app:chipStrokeColor="@color/accent_cyan"
                app:chipStrokeWidth="1dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipDepartment"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Department"
                android:textColor="@color/text_primary"
                app:chipBackgroundColor="@color/bg_card"
                app:checkedIconEnabled="false"
                app:chipStrokeColor="@color/accent_violet"
                app:chipStrokeWidth="1dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipOther"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Other"
                android:textColor="@color/text_primary"
                app:chipBackgroundColor="@color/bg_card"
                app:checkedIconEnabled="false"
                app:chipStrokeColor="@color/accent_green"
                app:chipStrokeWidth="1dp" />
        </com.google.android.material.chip.ChipGroup>

        <!-- ── Description ──────────────────────────────────────── -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilDescription"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xl"
            android:hint="Description (optional)"
            app:boxStrokeColor="@color/accent_green"
            app:hintTextColor="@color/accent_green"
            app:counterEnabled="true"
            app:counterMaxLength="200">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine"
                android:maxLength="200"
                android:minLines="3"
                android:textColor="@color/text_primary" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- ── Public Toggle ────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xl"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Public Team"
                    android:textAppearance="@style/TextAppearance.Eco.TitleMedium"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Anyone can find and join"
                    android:textAppearance="@style/TextAppearance.Eco.LabelSmall"
                    android:textColor="@color/text_muted" />
            </LinearLayout>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchPublic"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                app:thumbTint="@color/accent_green"
                app:trackTint="@color/bg_elevated" />
        </LinearLayout>

        <!-- ── Create Button ────────────────────────────────────── -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCreate"
            style="@style/Widget.Material3.Button"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="@dimen/spacing_xxl"
            android:text="Create Team"
            android:textColor="@color/text_on_accent"
            app:backgroundTint="@color/accent_green" />

        <!-- ── Loading ──────────────────────────────────────────── -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/spacing_md"
            android:indeterminateTint="@color/accent_green"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
