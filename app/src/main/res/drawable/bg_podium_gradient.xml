<?xml version="1.0" encoding="utf-8"?>
<!-- Podium gradient background (subtle green fading down) -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:angle="270"
        android:startColor="#33A3F77B"
        android:endColor="#00000000"
        android:type="linear" />
    <corners android:topLeftRadius="@dimen/radius_md"
        android:topRightRadius="@dimen/radius_md" />
</shape>
